# Tokito — copy to .env beside Tokito.exe or repo root
#
# AI builds the board; you edit the result. Both keys below are required for Build.

TOKITO_XAI_API_KEY=
TOKITO_FIRECRAWL_API_KEY=

TOKITO_HTTP_ADDR=0.0.0.0:8080
# Embedded PostgreSQL (pg-embed). Data: %LOCALAPPDATA%/tokito/postgres (Windows) or ~/.local/share/tokito/postgres (Linux).
# Maven bundle version (16 default; try 17/18 if unpack fails on your machine): 16 | 17 | 18
# TOKITO_PG_EMBED_VERSION=16
# TOKITO_EMBEDDED_PORT=15432
TOKITO_DB_MAX_CONNECTIONS=10
TOKITO_CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:5175

# JWT signing secret — required for release API builds (debug builds use a dev default)
# TOKITO_JWT_SECRET=

# xAI Grok (OpenAI-compatible): https://docs.x.ai/docs/tutorial
# TOKITO_XAI_BASE_URL=https://api.x.ai/v1

# Firecrawl (datasheet / web research): https://docs.firecrawl.dev/
# TOKITO_FIRECRAWL_BASE_URL=https://api.firecrawl.dev/v1

# Nexar Supply (optional — better package/footprint hints in catalog search)
# TOKITO_NEXAR_CLIENT_ID=
# TOKITO_NEXAR_CLIENT_SECRET=
# TOKITO_NEXAR_SCOPE=nexar-supply

# LCSC catalog search (anonymous endpoint; enabled by default — set false to disable)
TOKITO_LCSC_ANONYMOUS_SEARCH=true

# Agent tool-loop budgets (server enforced)
# TOKITO_AGENT_MAX_ITERATIONS=10
# TOKITO_AGENT_MAX_LLM_TOKENS=96000
# TOKITO_AGENT_MODEL=grok-4.3

# Integration tests that start embedded Postgres (optional locally — set to 1; CI uses GITHUB_ACTIONS)
# TOKITO_RUN_DB_INTEGRATION=1

# Integration tests: optional alternate embedded port (default binds ephemeral port)
# TOKITO_TEST_EMBEDDED_PORT=17334
