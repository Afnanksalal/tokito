# Tokito API — copy to .env for local development
#
# Copilot pipeline (native “Generate” + POST /v1/designs/:id/schematic/suggest):
# requires BOTH keys below — plan → Firecrawl web search → BOM → schematic.
# TOKITO_XAI_API_KEY=
# TOKITO_FIRECRAWL_API_KEY=

TOKITO_HTTP_ADDR=0.0.0.0:8080
TOKITO_DATABASE_URL=postgres://tokito:tokito@localhost:5433/tokito?sslmode=disable
TOKITO_DB_MAX_CONNECTIONS=10
TOKITO_CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:5175

# JWT signing secret — REQUIRED outside toy environments (defaults insecure when unset)
# TOKITO_JWT_SECRET=

# Nexar Supply (Octopart-class GraphQL): https://nexar.com / Nexus portal
# TOKITO_NEXAR_CLIENT_ID=
# TOKITO_NEXAR_CLIENT_SECRET=
# TOKITO_NEXAR_SCOPE=nexar-supply

# LCSC anonymous discovery toggle (best-effort; signed LCSC partner API not wired here)
# TOKITO_LCSC_ANONYMOUS_SEARCH=true

# Agent tool-loop budgets (server enforced)
# TOKITO_AGENT_MAX_ITERATIONS=10
# TOKITO_AGENT_MAX_LLM_TOKENS=96000
# TOKITO_AGENT_MODEL=grok-4.3

# Optional — server-side proxies (never expose keys to the browser)
# xAI Grok (OpenAI-compatible): https://docs.x.ai/docs/tutorial
# TOKITO_XAI_API_KEY=
# TOKITO_XAI_BASE_URL=https://api.x.ai/v1

# Firecrawl: https://docs.firecrawl.dev/
# TOKITO_FIRECRAWL_API_KEY=
# TOKITO_FIRECRAWL_BASE_URL=https://api.firecrawl.dev/v1

# Integration tests only:
# TOKITO_TEST_DATABASE_URL=postgres://tokito:tokito@localhost:5433/tokito_test?sslmode=disable
